# Windy Webcams API key (required for CCTV camera feeds)
WINDY_WEBCAMS_KEY=your_key_here

# Cesium Ion token (required for Cesium world terrain/imagery)
CESIUM_ION_TOKEN=your_cesium_token_here

# Optional GPS jamming source overrides
# GPS_JAM_URL=
# GPS_JAM_URL_TEMPLATE=
# GPS_JAM_URL_TEMPLATES=https://rfi.stanford.edu/{YYYY-MM-DD}_{type}.json

# Optional ISS source override
# ISS_API_URL=https://api.wheretheiss.at/v1/satellites/25544
# ISS_API_URLS=https://api.wheretheiss.at/v1/satellites/25544,http://api.open-notify.org/iss-now.json

# Optional strict demo-mode validation
# If true, startup fails when required demo keys are missing.
# DEMO_MODE=true
